package codechef;
import java.util.*;
	
public class FUNRUN {
	 static final int INT_BITS = 32;
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
		int A=sc.nextInt();
		int B=sc.nextInt();
		int len=Integer.toBinaryString(B).length();
		System.out.println(len);
	    int max=0;
	    int op=0;
	    for(int i=1;i<len;i++)
	    {
	    	System.out.println(B);
	       int b=circularRightShift(B, i);
	       System.out.println(b);
	       int val=A^b;
	       if(val>max)
	       {
	    	   max=val;
	    	   op=i;
	       }
	       
	    }
		System.out.println(op+" "+max);
	    
	}	
}
  public static int circularRightShift(int input, int n) {
	    int numBitsInInt = 32;
	    n = n % numBitsInInt;
	    int result = input >>> n | input << (numBitsInInt - n);
	    return result;
	}
  
}
