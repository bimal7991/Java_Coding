package codechef;
import java.util.*;

public class July3 {
   public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0) {
		int n=sc.nextInt();
		int arr[]=new int[n];
		for(int i=0;i<n;i++)
		   arr[i]=sc.nextInt();
		
		int max=0;
		for(int i=0;i<n;i++)
		{
			for(int j=i+1;j<n;j++)
			{
				if(binary(arr[i],arr[j])>max)
                  max=binary(arr[i],arr[j]);				
			}
		}
		
		System.out.println(max);
	}
	
	
	}

private static int binary(int x, int y) {
	// TODO Auto-generated method stub
	
	String binx=Integer.toBinaryString(x);
	String biny=Integer.toBinaryString(y);
	String binxy=binx+biny;
	String binyx=biny+binx;
	
	int xy=Integer.parseInt(binxy,2);
	int yx=Integer.parseInt(binyx,2);
	
	  
	
	
	
	return xy-yx;
}
  
}