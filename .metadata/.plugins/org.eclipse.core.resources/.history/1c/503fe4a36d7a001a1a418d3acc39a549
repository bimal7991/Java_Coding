package codechef;
import java.util.*;
public class SQUARED {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		while(T-->0)
		{
			int N=sc.nextInt();
			long arr[]=new long[N];
			for(int i=0;i<N;i++)
				arr[i]=sc.nextLong();

			for(int i=0;i<N;i++)
			{
				if(arr[i]<0)
					arr[i]=-arr[i];

			}
			int hash[]=new int[N];
			for(int i=0;i<N;i++)
			{
				if(arr[i]==0)
					hash[i]=2;
				else
				{
					hash[i]=arr[i]/2;
				}
			}
			
			
			
			
		}
	}
}
