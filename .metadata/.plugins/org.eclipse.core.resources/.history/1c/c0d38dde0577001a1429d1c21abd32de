package codechef;
import java.util.*;
public class UNITGCD {
	public static void main(String[] args) {
		
		ArrayList<Integer> coprime=new ArrayList<Integer>();
		coprime.add(1);
		for(int i=2;i<100000;i++)
		{
			int flag=0;
		   for(int j=0;j<coprime.size();j++)
		   {
			   if(gcd(i,coprime.get(j))!=1)
			   {
				   flag=1;
				   break;
			   }
		   }
		   if(flag==0)
			   coprime.add(i);
		}
		System.out.println(coprime);
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		while(T-->0)
		{
			int n=sc.nextInt();
			int arr[]=new int[n+1];
			int test[]=new int[n+1];
			Arrays.fill(test, -1);
			for(int i=1;coprime.get(i)<=n;i++)
			{
				arr[coprime.get(i)]=-1;
			}
			int count=1;
			while(!Arrays.equals(arr, test))
			{
				ArrayList<Integer> list=new ArrayList<Integer>();
				for(int i=1;i<=n;i++)
				{
					if(arr[i]!=-1)
					{
					    if(list.size()==0)
					    	list.add(i);
					    arr[i]=-1;
					    
					    break;
					}
			
				}
				for(int i=1;i<=n;i++)
				{
					if(arr[i]!=-1)
					{
						int flag=0;
						   for(int j=0;j<list.size();j++)
						   {
							   if(gcd(i,list.get(j))!=1)
							   {
								   flag=1;
								   break;
							   }
						   }
						   if(flag==0)
						   {
							   list.add(i);
							   arr[i]=-1;
						   }
					}
					
			
				}
				
				count++;
				
			}
			System.out.println(count);
			
		}
		
	}
	static int gcd(int a, int b) 
    { 
      if (b == 0) 
        return a; 
      return gcd(b, a % b);  
    } 

}
