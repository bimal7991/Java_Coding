package codechef;
import java.util.*;
public class CHPINTU {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		while(T-->0)
		{
			int n=sc.nextInt(),m=sc.nextInt();
			int P[]=new int[n];
			int F[]=new int[n];
			for(int i=0;i<n;i++)
			{
				F[i]=sc.nextInt();
			}
			for(int i=0;i<n;i++)
			{
				P[i]=sc.nextInt();
			}
			int hash[]=new int[m+1];
			for(int i=0;i<n;i++)
			{
				hash[F[i]]=hash[F[i]]+P[i];
			}
//			for(int i=1;i<=m;i++)
//			{
//				System.out.print(hash[i]+" ");
//			}
			int find0=0;
			for(int i=0;i<n;i++)
			{
				if(P[i]==0)
				{
					if(hash[F[i]]==0)
					{
						System.out.println(0);	
						find0=1;
					}
				}
			}
			if(find0==1)
				continue;
			int small=Integer.MAX_VALUE;
			for(int i=1;i<=m;i++)
			{
				if(hash[i]<small && hash[i]!=0)
					small=hash[i];
					
			}
			System.out.println(small);	
		}
		
	}

}
