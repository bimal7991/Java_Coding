import java.util.*;
import java.lang.*;
import java.io.*;

class Sum {
	public static void main (String[] args) {
		Scanner sc=new Scanner(System.in);
		int t=sc.nextInt();
		for(int j=0;j<t;j++)
		{
		    int n=sc.nextInt(),i;
		    int arr[]=new int[n];
		    for(i=0;i<n;i++)
		    {
		        arr[i]=sc.nextInt();
		    }
		    Arrays.sort(arr);
		    int c=0,count=0,k=n-2;
		    while(k>0)
		    {
		        if(arr[c]+arr[k]==arr[k+1])
		        count++;
		        else if(arr[c]+arr[k]<arr[k+1])
		        c++;
		        else
		        k--;
		        if(c==k-1)
		        c=0;
		    }
		    System.out.println(count);
		    
		}
	}
}