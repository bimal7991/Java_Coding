package codechef;
import java.util.*;
public class STRNO {
   public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
	  int X=sc.nextInt();
	  int K=sc.nextInt();
	  if(Math.pow(2, K)<=X)
	  {
		  System.out.println(1);
	  }
	  else
	  {
		  System.out.println(0);
	  }
	  
	}
 }
   
   
}
