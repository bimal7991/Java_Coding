package codechef;
import java.time.DayOfWeek;
import java.util.*;
public class LONGCOOK {
  public static void main(String[] args) {
	 Scanner sc=new Scanner(System.in);
	 int arr[]=new int[100000000];
	 int intersect[]=new int[100000000];
	 for(int i=1;i<100000000;i++)
	 {
		 if((checkYear(i)) && dayofweek(1, 2, i)==6)
    	 arr[i]=1;
         else if(dayofweek(1,2,i)==6 || dayofweek(1, 2, i)==0)
          {
             arr[i]=1;	
  //System.out.println(i+" ");
          }
		 
	 }
	 int sum=0;
	 for(int i=1;i<100000000;i++)
	 {
		 sum=sum+arr[i];
		 intersect[i]=sum;
	 }
	 
	 
	 
	 
	 
	 int T=sc.nextInt();
	 while(T-->0)
	 {
		 int m1=sc.nextInt(),y1=sc.nextInt(),m2=sc.nextInt(),y2=sc.nextInt();
		 int count=0;
		 int first=0,last=0;
		 if(m1<=2)
			 first=intersect[y1];
		 else
			 first=intersect[y1+1];
		 
		 if(m2>=2)
			 last=intersect[y2];
		 else
			 last=intersect[y2-1];
		
			
		 
		 System.out.println(last-first);
		 
		 
	 }
}
  static int dayofweek(int d, int m, int y)  
  {  
	  int t[] = { 0, 3, 2, 5, 0, 3, 5, 1, 4, 6, 2, 4 }; 
	    y -= (m < 3) ? 1 : 0; 
	    return ( y + y/4 - y/100 + y/400 + t[m-1] + d) % 7; 
  }  
  static boolean checkYear(int year) 
  { 
      // If a year is multiple of 400,  
      // then it is a leap year 
      if (year % 400 == 0) 
          return true; 
    
      // Else If a year is muliplt of 100, 
      // then it is not a leap year 
      if (year % 100 == 0) 
          return false; 
    
      // Else If a year is muliplt of 4, 
      // then it is a leap year 
      if (year % 4 == 0) 
          return true; 
      return false; 
  } 
  
}
