package codechef;
import java.util.*;
public class CHANDF {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		while(T-->0)
		{
			long x=sc.nextLong(),y=sc.nextLong(),l=sc.nextLong(),r=sc.nextLong();
			long max=0;
			long ans=l;
			for(long i=l;i<=r;i++)
			{
				long val=(x&i)*(y&i);
			
				System.out.print(val+" ");
				if(val>max)
				{
					max=val;
					ans=i;
				}
//				if(val==x*y)
//					break;1
			}
			System.out.println(ans);
		}
	}

}
