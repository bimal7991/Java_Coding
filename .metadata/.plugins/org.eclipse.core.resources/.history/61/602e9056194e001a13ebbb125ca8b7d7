package codechef;
import java.util.*;
public class NOCHANGE {
 public static void main(String[] args) {
	 Scanner sc=new Scanner(System.in);
	 int T=sc.nextInt();
	 while(T-->0)
	 {
		 int N=sc.nextInt();long P=sc.nextLong();
		 long arr[]=new long[N];
		 for(int i=0;i<N;i++)
			 arr[i]=sc.nextLong();
		 
		 long count[]=new long[N];
		 if(change(arr,P))
		 {
			 System.out.println("NO");
		 }
		 else
		 {
			 
		     long rem=P; 
			 int flag=0;
			 for(int i=N-1;i>=0;i--)
			 {
				 if(P%arr[i]==0)
					 continue;
				 else
				 {
					 count[i]=P/arr[i]+1;
					 flag=1;
					 break;
				 }
			 }
			 if(flag==0)
			 {
			 
						 count[N-1]=P/arr[N-1]-1;
						 rem=rem-arr[N-1]*count[N-1];
						 count[N-2]=rem/arr[N-2]+1;
					 
				 
			 }
			 
			 
			 
			 System.out.print("YES"+" ");
			 for(int j=0;j<N;j++)
			 {
				 if(j!=N-1)
				 System.out.print(count[j]+" ");
				 else
					 System.out.print(count[j]);
			 }
			 
			 System.out.println();
		 }
		 
		 
		 
	 }
}

private static boolean change(long[] arr,long P) {
	// TODO Auto-generated method stub
	long m1=arr[0];
	int flag=0;
	for(int i=1;i<arr.length;i++)
	{
	    if(arr[i]%m1==0)
	    {
	    	m1=arr[i];
	    }
	    else
	    {
	      return false;
	    }
	    	
	}
	if(P%arr[arr.length-1]==0)
		return true;
	else	
	   return false;
}
}
