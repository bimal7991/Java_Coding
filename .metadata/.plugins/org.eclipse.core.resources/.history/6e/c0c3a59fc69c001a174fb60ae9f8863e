package codechef;
import java.util.*;
public class TREE_OR_NOT {
   public static void main(String[] args) {    // A graph is a tree if np-of Connected compomnent is 1 and no of edges=node-1 
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
		int N=sc.nextInt(),M=sc.nextInt();
		for(int i=1;i<=N;i++)
		{
			arr[i]=new ArrayList<Integer>();
		}
		
		for(int i=0;i<M;i++)
		{
		   int u=sc.nextInt(),v=sc.nextInt();
		   arr[u].add(v);
		   arr[v].add(u);
		}
		int cc=0;
		for(int i=1;i<=N;i++)
		{
			if(vis[i]==0)
			{
				dfs(i);
			    cc++;	
			}
		}
		if(cc==1 && M==N-1)
		{
			System.out.println("YES");
		}
		else
			System.out.println("NO");
			

		
	}
 }
   static ArrayList<Integer> arr[]=new ArrayList[10001];
   static int vis[]=new int[10001];
   private static void dfs(int i) {
	// TODO Auto-generated method stub
	   vis[i]=1;
	   for(int child:arr[i])
	   {
		   if(vis[child]==0)
		   {
			   dfs(i);
		   }
	   }
	   
	
}

   
}
