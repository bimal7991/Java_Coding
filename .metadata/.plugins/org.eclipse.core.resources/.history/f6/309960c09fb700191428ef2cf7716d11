package codechef;
import java.util.*;
public class Flip_card {
public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int t=sc.nextInt();
	for(int j=0;j<t;j++)
	{
		String s=sc.next();
		int count1=0,count0=0;
		for(int i=0;i<s.length();i++)
		{
			if(s.charAt(i)=='1')
				count1++;
			else
				count0++;
			
				
		}
		if(count1<=count0)
			System.out.println("WIN");
		else
		System.out.println("LOSE");
		
	}
}
}
