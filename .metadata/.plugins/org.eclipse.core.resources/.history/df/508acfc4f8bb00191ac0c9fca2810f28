package codechef;

import java.lang.*;
import java.io.*;
import java.util.*;
class Sum {
	public static void main (String[] args) {
		Scanner sc=new Scanner(System.in);
		int t=sc.nextInt();
		for(int j=0;j<t;j++)
		{
		    int n=sc.nextInt(),i;
		    int arr[]=new int[n];
		    for(i=0;i<n;i++)
		    {
		        arr[i]=sc.nextInt();
		    }
		    int has[]=new int [100000];
		     //System.out.println(hm);
		   int sum=0,count=0;
		    for(i=0;i<n;i++)
		    {
		        for(int k=i+1;k<n;k++)
		        {
		            sum=arr[i]+arr[k];
		            has[sum]=sum;
		        }
		    }
		    for(i=0;i<has.length;i++)
		    {
		    	if(has[arr[i]]==arr[i])
		    		count++;
		    }
		    
		    System.out.println(count);
		}
	}
}