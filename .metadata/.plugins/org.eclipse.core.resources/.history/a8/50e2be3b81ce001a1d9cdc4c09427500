package codechef;
import java.util.*;

public class July1 {
   public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0) {
		  int n=sc.nextInt();
		  int k=sc.nextInt();
		  int arr[]=new int[n];
		  for(int i=0;i<n;i++)
		  {
			  arr[i]=sc.nextInt();
			  if(arr[i]%k==0)
				  System.out.print(1);
			  else
				  System.out.print(0);
		  }
		  System.out.println();
	}
}
}
