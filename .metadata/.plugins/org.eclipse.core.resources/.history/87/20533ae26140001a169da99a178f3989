package codechef;
import java.util.*;
public class Flood_fill_algo {
 public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
		int N=sc.nextInt();
		int M=sc.nextInt();
		int arr[][]=new int[N][M];
		for(int row=0;row<N;row++)
		{
			for(int col=0;col<M;col++)
			{
				arr[row][col]=sc.nextInt();
			}
		}
		
		int x=sc.nextInt(),y=sc.nextInt(),k=sc.nextInt();
		Dfs(arr,x,y,k);
		//System.out.println(count);
		for(int i=0;i<N;i++)
		{
			for(int j=0;j<M;j++)
			{
				System.out.print(arr[i][j]+" ");
			}
			System.out.println();
		}
		
	}
 }
static int c=0;
 
private static int[][] Dfs(int[][] arr, int row, int col,int k) {
	// TODO Auto-generated method stub
	if(row<0 ||row>=arr.length || col<0 || col>=arr[0].length)
		return arr;
	
	
	arr[row][col]=k;
	Dfs(arr, row+1, col,k);
	Dfs(arr, row-1, col,k);
	Dfs(arr, row, col+1,k);
	Dfs(arr, row, col-1,k);
	Dfs(arr, row+1, col+1,k);
	Dfs(arr, row+1, col-1,k);
	Dfs(arr, row-1, col+1,k);
	Dfs(arr, row-1, col-1,k);
	return arr;
}
}
