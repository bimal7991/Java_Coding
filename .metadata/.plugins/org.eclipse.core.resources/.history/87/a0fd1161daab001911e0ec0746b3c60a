package codechef;
import java.util.*;
public class Special {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int t=sc.nextInt();
		for(int i=0;i<t;i++)
		{
			String str=sc.next();
			int k1=0,k2=0;
			for(int j=0;j<str.length();j++)
			{
				if(str.charAt(j)=='1')
					k1++;
				else
					k2++;
					
			}
		}
	}

}
