package codechef;
import java.util.*;
public class THEATRE {
 public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
	int N=sc.nextInt();
	int arr[][]=new int[4][13];
	for(int i=0;i<N;i++)
	{
		String s=sc.next();
        String R=sc.next();
        sc.nextLine();
       int r=Integer.parseInt(R);
	   arr[s.charAt(0)-'A'][r]++;
		
	}
	for(int i=0;i<4;i++)
	{
		for(int j=3;j<=12;j+=3)
		{
			System.out.print(arr[i][j]+" ");
		}
		System.out.println();
	}
    
	}
}
}
