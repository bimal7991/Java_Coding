package codechef;
import java.util.*;
public class Variance {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int n=sc.nextInt();
	int k=sc.nextInt();
	int arr[]=new int[n];
	for(int i=0;i<n;i++)
	{
		arr[i]=sc.nextInt();
	}
	int count=0;
	int i = 0; 
    int j = n - 1; 
    Arrays.sort(arr);
    // Traverse the array 
    while (i < j) { 
  
        // If product is less than k 
        // then count that pair 
        // and increment 'i' 
        if (Math.abs(arr[i] - arr[j]) >= k) { 
            count += (j - i); 
            i++; 
        } 
  
        // Else decrement 'j' 
        else { 
            j--; 
        } 
    } 
	System.out.println(count);
}
}
