				{
				  m=Integer.parseInt(str[i],arr[i]);
				  
				}
					
			}
			for(int i=0;i<n;i++)
			{
				for(int j=2;j<=16;j++)
				{
					if(arr[i]==-1)
					{
						if(Integer.parseInt(str[i],j)==m)
					}
				}
			}
			
		}
	}

}
