package codechef;
import java.util.*;
public class CHEFRAIL {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	 while(T-->0)
	 {
		 int N=sc.nextInt();
		 int M=sc.nextInt();
		 int X[]=new int[N];
		 int Y[]=new int[M];
		 
		 int pos=0,neg=0,x=0,y=0;
		 for(int i=0;i<N;i++)
		 {
			 X[i]=sc.nextInt();
			 if(X[i]<0)
			 {
				 neg++;
			 }
			 else if(X[i]>0)
			 {
				 pos++;
			 }
			 else
			 {
				 x=1;
			 }
			
		 }
		 int xpos[]=new int[pos];
		 int xneg[]=new int[neg];
		 int j=0,k=0;
		 for(int i=0;i<N;i++)
		 {
			if(X[i]<0)
			{
				xneg[j++]=X[i];
			}
			else if(X[i]>0)
			{
				xpos[k++]=X[i];
			}
			
		 }
		 
		 
		 pos=0;neg=0;
		 for(int i=0;i<M;i++)
		 {
			 Y[i]=sc.nextInt();
			 if(Y[i]<0)
			 {
				 neg++;
			 }
			 else if(Y[i]>0)
			 {
				 pos++;
			 }
			 else
				 y=1;
		 }
		 int ypos[]=new int[pos];
		 int yneg[]=new int[neg];
		  j=0;k=0;
		 for(int i=0;i<M;i++)
		 {
			if(Y[i]<0)
			{
				yneg[j++]=Y[i];
			}
			else if(Y[i]>0)
			{
				ypos[k++]=Y[i];
			}
		 }
		 int count=0;
		 for(int i=0;i<xpos.length;i++)
		 {
			 for( j=0;j<ypos.length;j++)
			 { 
				 for( k=0;k<yneg.length;k++)
				 {
					 if(Right(xpos[i],ypos[j],-yneg[k]))
					 {
						count++; 	
						
					 }
					 
				 }
				 
			 }
		 }
		 for(int i=0;i<xneg.length;i++)
		 {
			 for( j=0;j<ypos.length;j++)
			 { 
				 for( k=0;k<yneg.length;k++)
				 {
					 if(Right(-xneg[i],ypos[j],-yneg[k]))
					 {
						count++; 
						
					 }
					 
				 }
				 
			 }
		 }
		 
		 
		 for(int i=0;i<ypos.length;i++)
		 {
			 for(j=0;j<xpos.length;j++)
			 {
				 
				 for( k=0;k<xneg.length;k++)
				 {
					 if(Right(ypos[i],xpos[j],-xneg[k]))
					 {
						 count++;
						
					 }
				}
			}
		 }
		 for(int i=0;i<yneg.length;i++)
		 {
			 for(j=0;j<xpos.length;j++)
			 {
				 
				 for( k=0;k<xneg.length;k++)
				 {
					 if(Right(-yneg[i],xpos[j],-xneg[k]))
					 {
						 count++;
						
					 }
				}
			}
		 }
		 if(x==1 || y==1)
		 {
			 count=count+(xpos.length+xneg.length)*(ypos.length+yneg.length);
		 }
		 System.out.println(count);
		 
		 }
		 
	 
}

private static boolean Right(int x1, int x2, int x3) {
	// TODO Auto-generated method stub
	if((x1*x1)==x2*x3)
		return true;
	else
		return false;
	
}
 
}
