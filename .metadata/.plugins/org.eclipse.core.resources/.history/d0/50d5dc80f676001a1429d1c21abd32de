package codechef;
import java.util.*;
public class STRANGE {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		while(T-->0)
		{
		  long X=sc.nextInt();
		  long K=sc.nextInt();
		  if(K==1)
			  System.out.println(1);
		  else if(K==2)
		  {
			  if(X>=4 && (X%2==0 || X%3==0))
				  System.out.println(1);
			  else
				  System.out.println(0);
		  }
		  
		  
		}
	}

}
