package codechef;
import java.util.*;
 class PHCUL {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		for(int t=0;t<T;t++)
		{
			int x=sc.nextInt(),y=sc.nextInt();
			int n=sc.nextInt(),m=sc.nextInt(),k=sc.nextInt();
			int narr[][]=new int[n][2],marr[][]=new int[m][2],karr[][]=new int[k][2];
			double reddist[]=new double[n],greendist[]=new double[m],bluedist[]=new double[k];

			double smallred=Double.MAX_VALUE;int redind=0;
			for(int i=0;i<n;i++)
			{
				narr[i][0]=sc.nextInt();
				narr[i][1]=sc.nextInt();
				reddist[i]=Math.sqrt((double)(narr[i][0]-x)*(narr[i][0]-x) + (double)(narr[i][1]-y)*(narr[i][1]-y));
				
			}
			//System.out.println(smallred);
			double smallgreen=Double.MAX_VALUE;int greenind=0;
			for(int i=0;i<m;i++)
			{
				marr[i][0]=sc.nextInt();
				marr[i][1]=sc.nextInt();
				greendist[i]=Math.sqrt((double)(marr[i][0]-x)*(marr[i][0]-x) + (double)(marr[i][1]-y)*(marr[i][1]-y));
			}
			for(int i=0;i<k;i++)
			{
				karr[i][0]=sc.nextInt();
				karr[i][1]=sc.nextInt();
			}
			
			//System.out.println(smallgreen);
			
			double dis[]=new double[m];
			for(int i=0;i<m;i++)
			{
				double totalred=Double.MAX_VALUE;
               for(int j=0;j<n;j++)
               {
            	   reddist[j]=reddist[j]+caldistance(marr[i][0], marr[i][1], narr[j][0], narr[j][1]);
            	   if(reddist[j]<totalred)
            		   totalred=reddist[j];
               }
               dis[i]=totalred;
			}
			 
			double dis2[]=new double[m];
			for(int i=0;i<m;i++)
			{
				double totalred=Double.MAX_VALUE;
               for(int j=0;j<k;j++)
               {
            	  double red=caldistance(marr[i][0], marr[i][1], karr[j][0], karr[j][1]);
            	   if(red<totalred)
            		   totalred=red;
               }
               dis2[i]=totalred+dis[i];
			}
			double min1=dis2[0];
			for(int i=1;i<m;i++)
			{
			   if(dis2[i]<min1)
				   min1=dis2[i];
			}
			
			double dis3[]=new double[n];
			for(int i=0;i<n;i++)
			{
			   double totalred=Double.MAX_VALUE;
               for(int j=0;j<m;j++)
               {
            	   greendist[j]=greendist[j]+caldistance(marr[j][0], marr[j][1], narr[i][0], narr[i][1]);
            	   if(greendist[j]<totalred)
            		   totalred=greendist[j];
               }
               dis3[i]=totalred;
			}
			double dis4[]=new double[n];
			for(int i=0;i<n;i++)
			{
				double totalred=Double.MAX_VALUE;
               for(int j=0;j<k;j++)
               {
            	  double red=caldistance(narr[i][0], narr[i][1], karr[j][0], karr[j][1]);
            	   if(red<totalred)
            		   totalred=red;
               }
               dis4[i]=totalred+dis3[i];
			}
			double min2=dis4[0];
			for(int i=0;i<n;i++)
			{
				System.out.print(dis4[i]+" ");
			   if(dis4[i]<min2)
				   min2=dis4[i];
			}
			System.out.println(Math.min(min1, min2));
		}

	}
	static double caldistance(int x1,int y1,int x2,int y2)
	{
		return Math.sqrt((double)(x1-x2)*(x1-x2) + (double)(y1-y2)*(y1-y2));
	}

}
