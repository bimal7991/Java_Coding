package codechef;
import java.util.*;
public class Crane {
     public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),h=sc.nextInt();
		int arr[]=new int[n];
		for(int i=0;i<n;i++)
		{
			arr[i]=sc.nextInt();
		}
		while(true)
		{
			
			int mv=0,flag=0;
			int quiet=0;
			
				switch(sc.nextInt()) {
				case 0:
					quiet=1;
					break;
					
				case 1:
					if(mv!=0)
					{
						mv=mv-1;
					  System.out.print("back");
					}
				     break;
				case 2:
					if(mv!=n-1)
					{
						mv=mv+1;
						System.out.print("forward");
					}
				    break;
				case 3:
					if(flag==0 && arr[mv]!=0)
					{
						arr[mv]=arr[mv]-1;
						flag=1;
						System.out.print("pick");
					}
					break;
				case 4:
					if(arr[mv]!=h && flag==1)
				{
					arr[mv]=arr[mv]+1;
					System.out.print("drop");
					flag=0;
				}
					break;
					
				
			}
				if(quiet==1)
					break;
				
			}
	
		for(int i=0;i<n;i++)
		{
			System.out.print(arr[i]+" ");
		}
	}
}
