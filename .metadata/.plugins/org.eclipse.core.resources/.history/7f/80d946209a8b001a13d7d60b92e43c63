package codechef;
import java.util.*;
public class CORUS {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
		int N=sc.nextInt(),Q=sc.nextInt();
		String str=sc.next();
		sc.nextLine();
		
		int hash[]=new int[26];
		for(int i=0;i<str.length();i++)
		{
			hash[str.charAt(i)-'a']++;
		}
		while(Q-->0)
		{
			int c=sc.nextInt();
			int sum=0;
			for(int i=0;i<26;i++)
			{
				sum=sum+hash[i]-c>=0?(hash[i]-c):0;
			}
			System.out.println(sum);
		}
		
	}
}
}
