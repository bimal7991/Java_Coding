package codechef;
import java.util.*;
public class Chew {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),k=sc.nextInt();
		int arr[]=new int[n];
		for(int i=0;i<n;i++)
		{
			arr[i]=sc.nextInt();
		}
			long count = 0; 
	    Arrays.sort(arr); // Sort array elements 
	    for(int i=0;i<n-1;i++)

	    {
	    	for(int j=n-1;j>i+1;j--)
	    	{
	    		if((arr[i]+arr[j])<k)
	    		{
	    			count=count+(j-i);
	    			break;
	    		}
	    		
	    	}
	    }
		System.out.println(count);
	}

}
