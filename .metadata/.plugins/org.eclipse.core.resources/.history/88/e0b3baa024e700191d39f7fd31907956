package codechef;
import java.util.*;
public class Price_drop {
	
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int t=sc.nextInt();
		for(int i=0;i<t;i++)
		{
			int n=sc.nextInt();
		    int arr[]=new int[n];
		    for(int j=0;j<n;j++)
		    {
		    	arr[j]=sc.nextInt();
		    	
		    }
		    int small=arr[0],count=0,small5=99999,k=1;
		    for(int j=1;j<n;j++)
		    {
		    	if(arr[j]>small & count!=5)
		    	{
		    		count++;
		    		if(arr[j]<small5)
		    			small5=arr[j];
		    		
		    			
		    	}
		    	else if(count==5)
		    	{
		    		if(arr[j]<small5)
		    		{		
		    		k++	;
		    		count=0;
		    		small=arr[j];
		    		small5=99999;
		    		}
		    	}
		    	
		    }
		    System.out.println(k);
		    
		}
		
	}

}
