package codechef;
import java.util.*;
public class Budget {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int n=sc.nextInt();
	int arr[]=new int[n];
	for(int i=0;i<n;i++)
	{
		arr[i]=sc.nextInt();
	}
	long ans=0;
	for(int i=0;i<n;i++)
	{
		if((long)(arr[i]*n)>ans)
		{
			int count=0;
		for(int j=0;j<n;j++)
		{
			if(arr[i]>=arr[j])
				count++;
		}
		if((long)(arr[i]*count)>ans)
			ans=(long)(arr[i]*count);
			
		}
	}
	System.out.println(ans);
}
}
