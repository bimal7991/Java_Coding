package codechef;
import java.util.*;
public class SQRDSUB2 {
     public static void main(String[] args) {
    	 Scanner sc=new Scanner(System.in);
 		int T=sc.nextInt();
 		while(T-->0)
 		{
 			int N=sc.nextInt();
 			int arr[]=new int[N];
 			for(int i=0;i<N;i++)
 				arr[i]=sc.nextInt();
 			
 			long count=0;
 			for(int i=0;i<N;i++)
 			{
 				if(arr[i]<0)
 					arr[i]=-arr[i];
 					
 			}
 			
 			
 			
 			
 			for(int i=0;i<N;i++)
 			{
 				long mult=1;
 				for(int j=i;j<N;j++)
 				{
 					mult=mult*arr[j];
 					if (mult%2==1 || mult%4==0)
 						count++;
 				}
 				
 			}
 			System.out.println(count);
 			
 			
 			
 		}
	}
}
