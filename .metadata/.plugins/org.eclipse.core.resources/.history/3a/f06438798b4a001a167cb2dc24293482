package codechef;
import java.util.*;
public class THEATRE {
 public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
	int N=sc.nextInt();
	int arr[][]=new int[4][13];
	for(int i=0;i<N;i++)
	{
		String s=sc.next();
        String R=sc.next();
        sc.nextLine();
       int r=Integer.parseInt(R);
	   arr[s.charAt(0)-'A'][r]++;
		
	}
	int th[][]=new int[4][4];
	for(int i=0;i<4;i++)
	{
		for(int j=3,k=0;j<=12 && k<4;j+=3,k++)
		{
			th[i][k]=arr[i][j];
		}
	}
	for(int i=0;i<4;i++)
	{
		for(int j=0;j<4;j++)
		{
			System.out.print(th[i][j]+" ");
		}
		System.out.println();
	}
	
	
    
	}
}
}
