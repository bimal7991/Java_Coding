package codechef;
import java.math.BigInteger;
import java.util.*;
public class Sequence2 {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		for(int t=0;t<T;t++)
		{
			int n=sc.nextInt(),k=sc.nextInt();
			int arr[]=new int[n];
			int freq[]=new int[100];
			for(int i=0;i<n;i++)
			{
				arr[i]=sc.nextInt();
				freq[arr[i]]++;
			}
			Arrays.parallelSort(arr);
			int sum=0;
			for(int i=0;i<k-1;i++)

			{
				if(arr[i]!=arr[i+1])
					sum=sum+freq[arr[i]];
			}
			sum=sum+freq[arr[k-1]]; 
			//System.out.println(sum);
			int arr1[]=new int[sum];
			for(int i=0;i<sum;i++)
			{
				arr1[i]=arr[i];
			}
			int count=0;
			for(int i=0;i<sum-1;i++)
			{
				if(arr1[i]!=arr1[i+1])
					count++;
			}
			count=count+1;
			//System.out.println(count);
			int min[]=new int[count];
			int seq[]=new int[count];
			int freq2[]=new int[1000];
			int a=0;
			int j=0;
			for(int i=0;i<k;i++)
				freq2[arr[i]]++;
			
			for(int i=0;i<k-1;i++)
			{
				
			    if(arr[i]!=arr[i+1])
			    {			    
			    	min[j++]=freq[arr[i]];
			    }
			    	
			}
			min[j]=freq2[arr[k-1]];
		  j=0;
			for(int i=0;i<sum-1;i++)
			{
				if(arr[i]!=arr[i+1])
			    {			    
			    	seq[j++]=freq[arr[i]];
			    }
			    	
			}
			seq[j]=freq[arr[sum-1]];
			BigInteger ans=new BigInteger("1");
			for(int i=0;i<count;i++)
			{
			   ans=ans*nCr(seq[i],min[i]);
			}
			System.out.println(ans);
            

		}
	}
	static BigInteger nCr(int n, int r) 
	{ 
	    return fact(n).divide((fact(r).multiply(fact(n - r))))  ;
	                  
	} 
	  
	// Returns factorial of n 
	static BigInteger fact(int n) 
	{ 
		 BigInteger res = new BigInteger("1"); 
	    for (int i = 2; i <= n; i++) 
	    	res = res.multiply(BigInteger.valueOf(i)); 
	    return res; 
	} 
	
	
}
