package codechef;
import java.util.*;
public class ANSLEAK {
   public static void main(String[] args) {
	   Scanner sc=new Scanner(System.in);
	   int T=sc.nextInt();
	   while(T-->0)
	   {
		   int n=sc.nextInt(),m=sc.nextInt(),k=sc.nextInt();
		   int arr[][]=new int[n][k];
		   int ans[]=new int[n];
		   for(int i=0;i<n;i++)
		   {
			   for(int j=0;j<k;j++)
			   {
				   arr[i][j]=sc.nextInt();
			   }
		   }
		   int hash[]=new int[m+1];
		   for(int i=0;i<n;i++)
		   {
			   for(int j=0;j<k;j++)
			   {
				  hash[arr[i][j]]++;
			   }
			   int max=0,ind=1;
			   for(int j=1;j<=m;j++)
			   {
				   if(hash[j]>max)
				   {
					   max=hash[j];
					   ind=j;
				   }
					   
			   }
			   ans[i]=ind;
			   
		   }
		   for(int i=0;i<n;i++)
		   {
			   System.out.print(ans[i]+" ");
		   }
		   System.out.println();
	   }
	
 }
}
