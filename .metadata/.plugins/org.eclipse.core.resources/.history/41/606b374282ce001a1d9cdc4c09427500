package codechef;
import java.util.*;

public class July1 {
   public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0) {
		  int n=sc.nextInt();
		  int k=sc.nextInt();
		  int arr[]=new int[n];
		  for(int i=0;i<n;i++)
		  {
			  int num=sc.nextInt();
			  if(num%k==0)
				 arr[i]=1;
			  else
				 arr[i]=0;
		  }
		  String s=arr.toString();
		  System.out.println(s);
	}
}
}
