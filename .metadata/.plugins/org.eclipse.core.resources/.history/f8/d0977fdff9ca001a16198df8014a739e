package codechef;
import java.util.*;
public class TOPLOGICAL_SORT {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int t=sc.nextInt();
		while(t-->0)
		{
			int n=sc.nextInt(),m=sc.nextInt();
			for(int i=1;i<=n;i++)
				arr[i]=new ArrayList<Integer>();
			
			for(int i=0;i<m;i++)
			{
				int u=sc.nextInt(),v=sc.nextInt();
				arr[u].add(v);
				in[v]++;
			}
			toplogical(n);

		}
	}

	private static void toplogical(int n) {
		// TODO Auto-generated method stub
		Queue< Integer> q=new LinkedList<Integer>();
		 
		PriorityQueue<Integer> pq= new PriorityQueue<>(arg0)
		
		 for(int i=1;i<=n;i++)
			if(in[i]==0)
				q.add(i);
		 
		 while(!q.isEmpty())
		 {
			 int p=q.peek();
			 res.add(p);
			 q.remove();
			 
			 for(int child:arr[p])
			 {
				 in[child]--;
				 if(in[child]==0)
				 {
					 q.add(child);
				 }
			 }
			 
		 }
		 for(int i=0;i<res.size();i++)
		 {
			 System.out.print(res.get(i)+" ");
		 }
		
		
	}

	static ArrayList<Integer> arr[]=new ArrayList[100001];
    static int in[]=new int[100001];
     static ArrayList<Integer> res=new ArrayList<Integer>();					
					
}
