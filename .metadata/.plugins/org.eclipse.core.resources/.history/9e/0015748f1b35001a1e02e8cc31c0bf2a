package codechef;
import java.util.*;
public class Boofish {
 public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	for(int t=0;t<T;t++)
	{
		int N=sc.nextInt();
		if(N%2!=0)
		{
			System.out.println("Boo");
			
		}
		else
		{
			int arr[][]=new int[N][N];
			int dig=2*N-1;
			int value=1;
			int rep=N/2;
			for(int i=0;i<N;i++)
			{
				for(int j=0;j<N;j++)
				{
					if(i!=j)
					{
				        arr[i][j]=value;
				        value++;
				        if(value>dig-1)
				        	value=1;
					}
					else
						arr[i][j]=2*N-1;
				}
			}
			System.out.println("Hooray");
			for(int i=0;i<N;i++)
			{
				for(int j=0;j<N;j++)
				{
					System.out.print(arr[i][j]+" ");
				}
			  System.out.println();
					
			}
			
		}
	   
				
	}
			
}
}
