package codechef;
import java.util.*;
public class NODE_DISTANCE {
   public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
		int n=sc.nextInt();
		for(int i=1;i<=n;i++)
			arr[i]=new ArrayList<Integer>();
		
		for(int i=1;i<n;i++)
		{
			int a=sc.nextInt(),b=sc.nextInt();
			arr[a].add(b);
			arr[b].add(a);
		}
		
		
		init(n);
		
	}
}
 private static void init(int n) {
	// TODO Auto-generated method stub
	 dfs(1,0,-1);
	 
	 
	
}
private static void dfs(int node, int lvl, int par) {
	
	// TODO Auto-generated method stub
	level[node]=lvl;
	LCA[node][0]=par;
	for(int child:arr[node])
	{
		if(child!=par)
		{
			dfs(child,lvl+1,node);
		}
	}
	
	
static ArrayList<Integer> arr[]=new ArrayList[1001];
 static int maxN=10;
 static int level[]=new int[1001];
 static int LCA[][]=new int[1001][maxN];
 
   
}
