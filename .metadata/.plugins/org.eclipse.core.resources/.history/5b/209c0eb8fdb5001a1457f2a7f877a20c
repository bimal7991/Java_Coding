package codechef;
import java.util.*;
public class TreeandQueries_Codeforce {
	
	static int timer;
	static int S[]=new int[1000001];
	static int T[]=new int[10000001];
	static int FT[]=new int[1000001];
	static ArrayList<Integer> arr[]=new ArrayList[1000001];
	static ArrayList<Query1> Q =new ArrayList<Query1>(); 
	static int col[]=new int[1000001];
	static int nodeF[]=new int[1000001];
	static int ans[]=new int[1000001];
	
	
     public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),q=sc.nextInt();
		for(int i=1;i<=n;i++)
			arr[i]=new ArrayList<Integer>();
		
		for(int i=1;i<=n;i++)
			col[i]=sc.nextInt();
		
		for(int i=1;i<n;i++)
		{
			int u=sc.nextInt(),v=sc.nextInt();
			arr[u].add(v);
			arr[v].add(u);
		}
		timer=1;
		dfs(1,-1);
		
		for(int i=0;i<q;i++)
		{
			int u=sc.nextInt(),k=sc.nextInt();
			int L=S[u],R=T[u];
			Q.add(new Query1(L, R, i, k));
			
		}
		int block = (int) Math.sqrt(n); 
		Collections.sort(Q, new Comparator<Query1>(){ 
			public int compare(Query1 x, Query1 y){ 


				if (x.L/block != y.L/block)  
					return (x.L < y.L ? -1 : 1);  

				return (x.R < y.R ? -1 : 1); 
			} 
		}); 

		 for(int i=0;i<Q.size();i++) {
		 System.out.println(Q.get(i).L+" "+Q.get(i).R+" "+Q.get(i).ind); }
		
		int ml=1,mr=0;
		for(int i=0;i<q;i++)
		{
			int L=Q.get(i).L;
			int R=Q.get(i).R;
			int ind=Q.get(i).ind;
			int k=Q.get(i).k;
			

			while(mr<R)
			{
				mr++;
				add(mr);

			}
			while(ml>L)
			{
				ml--;   
				add(ml);

			}


			while(mr>R)
			{
				remove(mr);
				mr--;
			}

			while (ml<L)
			{
				remove(ml);
				ml++;
			}
           
             ans[i]=getAns(i,n);



		}
		for(int i=0;i<q;i++)
			System.out.println(ans[i]);
		
		
		
		
		
		
	}


     private static int getAns(int k,int n) {
		// TODO Auto-generated method stub
    	 int sum=0;
    	 for(int i=k;i<=n;i++)
    	   sum=sum+ff[i];	 
    	 
    	 return sum;
		
	}


	static int f[]=new int[1000001];
     static int ff[]=new int[1000001];
    
     
	private static void remove(int mr) {
		// TODO Auto-generated method stub
		int node=FT[mr];
		nodeF[node]--;
		int c=col[node];
		
		
		if(nodeF[node]==1)
		{
			f[c]--;
			ff[f[c]]++;
			ff[f[c]+1]--;
			
		}
		
	}


	private static void add(int ml) {
		
		int node=FT[ml];
		nodeF[node]++;
		int c=col[node];
		
		
		if(nodeF[node]==2)
		{
			f[c]++;
			ff[f[c]]++;
			ff[f[c]-1]--;
			
		}
		
		
		
		
		
	}


	private static void dfs(int node, int parent) {
		// TODO Auto-generated method stub
		S[node]=timer;
		FT[timer]=node;
		timer++;
		
		for(int child:arr[node])
		{
			if(child!=parent)
				dfs(child,node);
		}
		T[node]=timer;
		FT[timer]=node;
		timer++;
		
		
		
		
		
	}
}
class Query1{  
	int L;  
	int R; 
	int ind;
	int k;
	Query1(int L, int R,int ind,int k){ 
		this.L = L; 
		this.R = R; 
		this.ind=ind;
		this.k=k;
	} 
}
