package codechef;
import java.util.*;
public class Chew {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),k=sc.nextInt();
		int arr[]=new int[n];
		for(int i=0;i<n;i++)
		{
			arr[i]=sc.nextInt();
		}
		long count=0;
		Arrays.sort(arr);
		for(int j=0;j<n;j++)
			System.out.println(arr[j]);
		int l=0;
		for(int i=0;i<n-1;i++)
		{
			for( l=i+1;l<n;l++);
			{
				
				if(arr[i]+arr[l]<k)
					count++;
				else
					break;
			}
		}
		System.out.println(count);
	}

}
