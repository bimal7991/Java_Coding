package codechef;
import java.util.*;
public class SUPW {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int n=sc.nextInt();
	int arr[]=new int[n];
	for(int i=0;i<n;i++)
		arr[i]=sc.nextInt();
	long sum=0;
	int k=n%3;
	for(int i=0;i<n-3-k;i+=3)
	{
		int max1=Math.min(arr[i], arr[i+1]);
		sum=sum+Math.min(max1, arr[i+2]);
	}
	if(k==1)
		sum=sum+arr[n-1];
	else if(k==2)
		sum=sum+Math.min(arr[n-1], arr[n-2]);
	else
	{}
	System.out.println(sum);
}
}
