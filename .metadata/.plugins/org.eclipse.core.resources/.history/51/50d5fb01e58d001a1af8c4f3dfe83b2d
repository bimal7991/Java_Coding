package codechef;

import java.util.*;

public class CHANDF {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		int T = sc.nextInt();
		while (T-- > 0) {
			long x = sc.nextLong(), y = sc.nextLong(), l = sc.nextLong(), r = sc.nextLong();
			long max = 0;
			
			if(x==0 || y==0)
				System.out.println(0);
			else
			{
			    long ans=x|y;
			    // System.out.println(ans);
			    if(r>=ans && l<=ans)
			    	System.out.println(ans);
			    else
			    {
			    	int bitx=Long.toBinaryString(x).length();
		    		int bity=Long.toBinaryString(y).length();
		    		String btr=Long.toBinaryString(ans);
		    		int minbit=Math.min(bitx, bity);
			    	if(l>ans)
			    	{
			    		
			    		
			    		String str=btr.substring(btr.length()-minbit,btr.length());
			    		System.out.println(str);
			    		long val=Long.parseLong(str,2);
			    		long ans2=val|l;
			    		System.out.println(ans2);	
			    	}
			    	else if(r<ans)
			    	{
			    		String str=btr.substring(btr.length()-minbit+1,btr.length());
			    		System.out.println(str);
			    		long val=Long.parseLong(str,2);
			    		long ans2=val|l;
			    		System.out.println(ans2);	
			    	}
			    	
			    	
			    	
			    	
			    	
			    	//System.out.println(btr);
			    	
			    	
			    }
			
			
			     
			}
			 

		}
	}

}
