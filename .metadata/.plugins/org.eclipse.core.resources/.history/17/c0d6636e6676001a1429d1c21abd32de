package codechef;
import java.util.*;
public class Codejam3 {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	for(int t=1;t<=T;t++)
	{
		int n=sc.nextInt();
		ArrayList<Character> ch=new ArrayList<Character>();
		int start[]=new int[n];
		int end[]=new int[n];
		for(int i=0;i<n;i++)
		{
			start[i]=sc.nextInt();
			end[i]=sc.nextInt();
		}
		
		ch.add('C');
		ch.add('J');
		int flag=0;
		for(int k=2;k<n;k++)
		{
			
				if(start[k]>=end[k-1])
				{
					ch.add(ch.get(k-1));
				}
				else
				{
					int j=k-1;
					while(j>=0 && start[k]<end[j] )
					{
						j--;
					}
					
					if(j<0)
					{
						flag=1;
						break;
					}
					else
					{
						ch.add(ch.get(j));
					}
				}
			
		}
		
		if(flag==1)
			System.out.println("IMPOSSIBLE");
		else
		{
			for(int i=0;i<ch.size();i++)
				System.out.print(ch.get(i));
		}
		System.out.println();
	}
}
}
