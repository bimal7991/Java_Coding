package codechef;
import java.util.*;
public class Matrix_odd {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int t=sc.nextInt();
	for(int i=0;i<t;i++)
	{
		int n=sc.nextInt(),m=sc.nextInt(),q=sc.nextInt();
		//int arr[][]=new int[n][m];
		int r[]=new int[n+1];
		int c[]=new int[m+1];
		for(int j=0;j<q;j++)
		{
			 r[sc.nextInt()]++;
			 c[sc.nextInt()]++;         
		
		}
		  Arrays.sort(r);
		  Arrays.sort(c);
		
		int count=0;
		for(int j=r.length-1;j>=1;j--)
		{
			if(r[j]==0)
				break;
			for(int k=c.length-1;k>=1;k--)
			{
				
				if(c[k]==0)
					break;
				else
				{
					if((long)(r[j]+c[k])%2!=0)
						count++;
				}
			}
		}
		
		
		System.out.println(count);
		
	}
}
}