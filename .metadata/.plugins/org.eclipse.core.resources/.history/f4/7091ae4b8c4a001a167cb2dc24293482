package codechef;
import java.util.*;
public class THEATRE {
 public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	long sum=0;
	while(T-->0)
	{
	int N=sc.nextInt();
	int arr[][]=new int[4][13];
	for(int i=0;i<N;i++)
	{
		String s=sc.next();
        String R=sc.next();
        sc.nextLine();
       int r=Integer.parseInt(R);
	   arr[s.charAt(0)-'A'][r]++;
		
	}
	int th[][]=new int[4][4];
	for(int i=0;i<4;i++)
	{
		for(int j=3,k=0;j<=12 && k<4;j+=3,k++)
		{
			th[i][k]=arr[i][j];
		}
	}
	int max[]=new int[4],ind=0;
	for(int j=0;j<4;j++)
	{
		for(int i=0;i<4;i++)
		{
			if(th[i][j]>max[j])
			{
				max[j]=th[i][j];
			    ind=i;	
			}
		}
		for(int i=0;i<4;i++)
		{
			th[ind][i]=0;
		}
	}
	Arrays.sort(max);
	if(max[0]>0)
	{
		sum=sum+max[0]*100;
	}
	else
		sum=sum-100;
	
	if(max[1]>0)
	{
		sum=sum+max[1]*75;
	}
	else
		sum=sum-100;
	
	if(max[2]>0)
	{
		sum=sum+max[2]*50;
	}
	else
		sum=sum-100;
	if(max[3]>0)
	{
		sum=sum+max[3]*25;
	}
	else
		sum=sum-100;
	
	
	
	
	
	System.out.println(sum);
	
	for(int i=0;i<4;i++)
	{
		for(int j=0;j<4;j++)
		{
			System.out.print(th[i][j]+" ");
		}
		System.out.println();
	}
	}
}
}
