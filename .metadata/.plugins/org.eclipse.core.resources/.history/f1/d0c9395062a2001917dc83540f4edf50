import java.util.*;
public class Max_min {
   public static void main(String[] args) {
	  
	Scanner sc=new Scanner(System.in);
	int t,i;
	t=sc.nextInt();
	for(i=0;i<t;i++)
	{
	   long n=sc.nextLong();
	   long k=sc.nextLong();
	   //int div=k/n;
	   if(n==0)
	   {
		   System.out.println(k);
		   break;
	   }
	   
       int rem=(int) (k%n);
      
       if(n%2==0)
       {
    	   if(n/2>rem)
    		   System.out.println(2*rem);
    	   else if(n/2==rem)
    		   System.out.println(2*rem-1);
    	   else
    		   System.out.println((2*(n-rem)));
       }
       else
       {
    	  if((n+1)/2>rem)
    		  System.out.println(2*rem);    		  
    	  else
    		  System.out.println(2*(n-rem));
    		  
       }
       
    	   
	   
	}

   
   
}
}
