		}
		int block = (int) Math.sqrt(n); 
		Collections.sort(Q, new Comparator<Query>(){ 
			public int compare(Query x, Query y){ 


				if (x.L/block != y.L/block)  
					return (x.L < y.L ? -1 : 1);  

