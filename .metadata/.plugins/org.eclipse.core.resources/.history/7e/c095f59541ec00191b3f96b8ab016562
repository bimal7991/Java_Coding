package codechef;
import java.util.*;
public class MSNG {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		for(int t=0;t<T;t++)
		{
			int n=sc.nextInt();
			int arr[]=new int[n];
			String str[]=new String[n];
			for(int i=0;i<n;i++)
			{
				arr[i]=sc.nextInt();
				str[i]=sc.next();
			}
			int m=0,maxlen=0,maxind=0;
			for(int i=0;i<n;i++)
			{
				if(arr[i]!=-1)
				{
				  m=Integer.parseInt(str[i],arr[i]);  
				}
				else
				{
					if(str[i].length()>maxlen)
					{
						maxlen=str[i].length();
						maxind=i;
					}
				}
				
					
			}
			System.out.println(m);
			if(m==0)
				m=Integer.parseInt(str[maxind],2);
			int flag=0;
			for(int i=0;i<n;i++)
			{
				flag=0;
				for(int j=2;j<=16;j++)
				{
					if(arr[i]==-1)
					{
						
						if(Integer.parseInt(str[i],j)==m)	
						{
						 flag=1;
						 System.out.println(flag);
						 break;
						}
					}
				}
				
				if(flag==0)
					break;
			}
			if(flag==0)
				System.out.println(-1);
			else
				System.out.println(m);
			
		}
	}

}
