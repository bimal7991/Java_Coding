package codechef;


import java.util.*;
public class TreeandQueries_Codeforce {
	
	static int timer,block=600;
	static int S[]=new int[100001];
	static int T[]=new int[100001];
	static int FT[]=new int[2*100001];
	static ArrayList<Integer> arr[]=new ArrayList[100001];
	static int  Q[][] =new  int[100001][4]; 
	static int col[]=new int[100001];
	static int nodeF[]=new int[100001];
	static int ans[]=new int[100001];
	static int bucket[]=new int[100001];
	
     public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt(),q=sc.nextInt();
		for(int i=1;i<=n;i++)
			arr[i]=new ArrayList<Integer>();
		
		for(int i=1;i<=n;i++)
			col[i]=sc.nextInt();
		
		for(int i=1;i<n;i++)
		{
			int u=sc.nextInt(),v=sc.nextInt();
			arr[u].add(v);
			arr[v].add(u);
		}
		timer=1;
		dfs(1,-1);
		
		for(int i=0;i<q;i++)
		{
			int u=sc.nextInt(),k=sc.nextInt();
			int L=S[u],R=T[u];
			System.out.println(L+" "+R);
			Q[i][0]=L;
			Q[i][1]=R;
			Q[i][2]=i;
			Q[i][3]=k;
			
			
		}
		
		for(int i=0;i<q;i++) {
			 System.out.println(Q[i][0]+" "+Q[i][1]+" "+Q[i][2]); }
		
		 Arrays.sort(Q, new Comparator<int[]>(){
	          public int compare(int[] a, int[] b){
	              if(a[1] == b[1]){
	                  return a[0] - b[0];
	              }
	              
	              return a[1]-b[1];  
	          }
	    });
		  

		 for(int i=0;i<q;i++) {
		 System.out.println(Q[i][0]+" "+Q[i][1]+" "+Q[i][2]); }
	
		int ml=1,mr=0;
		for(int i=0;i<q;i++)
		{
			int L=Q[i][0];
			int R=Q[i][1];
			int ind=Q[i][2];
			int k=Q[i][3];
			

			while(mr<R)
			{
				mr++;
				add(mr);

			}
			while(ml>L)
			{
				ml--;   
				add(ml);

			}


			while(mr>R)
			{
				remove(mr);
				mr--;
			}

			while (ml<L)
			{
				remove(ml);
				ml++;
			}
           
             ans[ind]=getAns(k,n);



		}
		for(int i=0;i<q;i++)
			System.out.println(ans[i]);
				
	}


     private static int getAns(int k,int n) {
		// TODO Auto-generated method stub
    	int Lb=getBlock(k);
    	int Rb=getBlock(n);
		int res=0;
		if(Lb==Rb)
		{
			for(int i=k;i<n;i++)
				res=res+ff[i];
		}
		else
		{
			for(int i=k;i<Lb*block;i++)
				res=res+ff[i];
			for(int i=Lb;i<Rb;i++)
			{
				res=res+bucket[i];
				
			}
			for(int i=Rb*block;i<n;i++)
				res=res+ff[i];
		}
		return res;
	}


	static int f[]=new int[100001];
     static int ff[]=new int[100001];
    
     
	private static void remove(int mr) {
		// TODO Auto-generated method stub
		int node=FT[mr];
		nodeF[node]--;
		int c=col[node];
		
		
		if(nodeF[node]==1)
		{
			f[c]--;
			ff[f[c]]++;
			bucket[getBlock(f[c])]++;
			
			ff[f[c]+1]--;
			bucket[getBlock(f[c]+1)]--;
		}
		
	}


	private static int getBlock(int i) {
		// TODO Auto-generated method stub
		return (i/block);
	}


	private static void add(int ml) {
		
		int node=FT[ml];
		nodeF[node]++;
		int c=col[node];
		
		
		if(nodeF[node]==2)
		{
			f[c]++;
			ff[f[c]]++;
			bucket[getBlock(f[c])]++;
			ff[f[c]-1]--;
			bucket[getBlock(f[c]-1)]--;
			
		}
		
		
		
		
		
	}


	private static void dfs(int node, int parent) {
		// TODO Auto-generated method stub
		S[node]=timer;
		FT[timer]=node;
		timer++;
		
		for(int child:arr[node])
		{
			if(child!=parent)
				dfs(child,node);
		}
		T[node]=timer;
		FT[timer]=node;
		timer++;
		
		
		
		
		
	}
}

