package codechef;
import java.util.*;
public class LONGCOOK {
  public static void main(String[] args) {
	 Scanner sc=new Scanner(System.in);
	 
	 int T=sc.nextInt();
	 while(T-->0)
	 {
		 int m1=sc.nextInt(),y1=sc.nextInt(),m2=sc.nextInt(),y2=sc.nextInt();
		 int count=0;
		 for(int i=y1;i<=y2;i++)
		 {
			 if(i==y1)
			 {
				 if(m1<=2)
				 {
					 if(checkYear(i))
					 {
						 if(method(1, 2, i)==0)
							 count++;
						 
					 }
					 else
					 {
						 if(method(1,2,i)==0 || method(1, 2, i)==1 )
							count++;
					 }
					 
				 }
			 }
			 else if(i==y2)
			 {
				 if(m2>=2)
				 {
					 if(checkYear(i))
					 {
						 if(method(1, 2, i)==0)
							 count++;
						 
					 }
					 else
					 {
						 if(method(1,2,i)==0 || method(1, 2, i)==1 )
							count++;
					 } 
				 }
			 }
			 else
			 {
				 if(checkYear(i))
				 {
					 if(method(1, 2, i)==0)
						 count++;
					 
				 }
				 else
				 {
					 if(method(1,2,i)==0 || method(1, 2, i)==1 )
						count++;
				 }  
			 }
		 }
		 System.out.println(count);
		 
	 }
}
  static int method(int day, int month, int year) 
{ 
if (month == 1) 
{ 
month = 13; 
year--; 
} 
if (month == 2) 
{ 
month = 14; 
year--; 
} 
int q = day; 
int m = month; 
int k = year % 100; 
int j = year / 100; 
int h = q + 13*(m + 1) / 5 + k + k / 4 + j / 4 + 5 * j; 
h = h % 7; 
return h;
}
  
  static boolean checkYear(int year) 
  { 
     
      if (year % 400 == 0) 
          return true; 
    
      
      if (year % 100 == 0) 
          return false; 
    
   
      if (year % 4 == 0) 
          return true; 
      return false; 
  } 
  
}
