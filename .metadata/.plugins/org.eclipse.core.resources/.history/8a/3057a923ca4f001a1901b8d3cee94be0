			 else if(i==y2)
			 {
				 
				 
				
					
					 if(m2<2 || (checkYear(i) && dayofweek(29,2,i)==0))
							continue;
					 else if((dayofweek(7,2,i)==5 && (dayofweek(16,2,i)==0 || dayofweek(15,2,i)==0 )) || (dayofweek(6,2,i)==5  && dayofweek(15,2,i)==0) )
