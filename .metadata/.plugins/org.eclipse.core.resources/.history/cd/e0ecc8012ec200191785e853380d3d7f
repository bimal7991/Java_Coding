		Scanner sc=new Scanner(System.in);
		int t=sc.nextInt();	
		for(int i=0;i<t;i++)
		{

			int n=sc.nextInt(),m=sc.nextInt();
			int arr[]=new int[n];
			int arr2[]=new int[m];
			int count[]=new int[100000];
			for(int j=0;j<n;j++)
			{
				arr[j]=sc.nextInt();
				count[arr[j]]++; 
			}
			for(int j=0;j<n;j++)
				arr2[j]=sc.nextInt();
			for(int j=0;j<m;j++)
			{
				while(count[arr2[j]]!=0)
				{
                   System.out.print(arr2[j]);    
				}


			}




		}

	}

}
