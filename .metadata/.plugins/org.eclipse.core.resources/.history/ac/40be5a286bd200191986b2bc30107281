package codechef;
import java.util.*;
public class Fib_seq {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int t=sc.nextInt();
		for(int T=0;T<t;T++)
		{
			long n=sc.nextLong();
			
			int k=1;
			while(Math.pow(2, k)<=n)
			{
				k++;
			}
			int fib[]=new int[(int) k];
			fib[0]=0;
			fib[1]=1;
			for(int i=2;i<k;i++)
			{
				
				fib[i]=fib[i-1]+fib[i-2];
			}
			for(int i=0;i<n;i++)
			{
				
				fib[i]=fib[i]%10;
				//System.out.print(fib[i]+" ");
				
			}
			System.out.println(fib[(int) (Math.pow(2, k-1)-1)]);
		}
		
	}
}
