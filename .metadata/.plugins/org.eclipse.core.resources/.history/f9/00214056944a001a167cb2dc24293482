package codechef;
import java.util.*;
public class THEATRE {
 public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	long sum=0;
	while(T-->0)
	{
	int N=sc.nextInt();
	int arr[][]=new int[4][13];
	for(int i=0;i<N;i++)
	{
		String s=sc.next();
        String R=sc.next();
        sc.nextLine();
       int r=Integer.parseInt(R);
	   arr[s.charAt(0)-'A'][r]++;
		
	}
	int th[][]=new int[4][4];
	for(int i=0;i<4;i++)
	{
		for(int j=3,k=0;j<=12 && k<4;j+=3,k++)
		{
			th[i][k]=arr[i][j];
		}
	}
	int max[]=new int[4],row=0,col=0;
	for(int k=0;k<4;k++)
	{
	  for(int i=0;i<4;i++)
	  {
		  for(int j=0;j<4;j++)
		  {
			  if(th[i][j]>max[k])
			  {
				  max[k]=th[i][j];
				  row=i;
				  col=j;
			  }
		  }
	  }
	  for(int i=0;i<4;i++)
	  {
		  th[row][i]=0;
		  th[i][col]=0;
	  }
	  row=0;
	  col=0;
	}
	long profit=0;
	Arrays.sort(max);
	for(int i=0;i<4;i++)
	{
		System.out.print(max[i]+" ");
	}
	System.out.println();
	
	if(max[3]>0)
		profit=profit+max[3]*100;
	else
		profit=profit-100;
	if(max[2]>0)
		profit=profit+max[2]*75;
	else
		profit=profit-100;
	if(max[1]>0)
		profit=profit+max[1]*50;
	else
		profit=profit-100;
	if(max[0]>0)
		profit=profit+max[0]*25;
	else
		profit=profit-100;
	
	sum=sum+profit;
	System.out.println(profit);
//	for(int i=0;i<4;i++)
//	{
