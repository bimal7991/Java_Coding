package codechef;
import java.util.*;
public class Row_excel {
   public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int n=sc.nextInt();
	int k=n;
	String s="A";
	while(n!=0)
	{
		int mod=n%26;
		n=n/26;
		if(mod==0)
		{
			s=s+'Z';
		    n=n-1;			
		}
		else
		{
			int m=64+mod;
			s=s+(char)m;
		}
	}
	System.out.println(s.substring(1));
	
}
}
