import java.util.Scanner;
import java.util.*;
public class Stealing {
public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int t=sc.nextInt();
	for(int j=0;j<t;j++)
	{
		int n=sc.nextInt();
		long arr[]=new long[n],sum=0;
		for(int i=0;i<n;i++)
		{
			arr[i]=sc.nextLong();
			sum=sum+arr[i];
			
		}
		long avg= (sum/n);
		long navg;
		boolean flag=false;
		for(int i=0;i<n;i++)
		{
			navg=((sum-(arr[i]))/(n-1));
				if(navg==avg)
				{
					System.out.println((i+1));
					flag=true;
					break;
					
				}
				
		}
		if(flag==false)
			System.out.println("Impossible");
	}
}
}
