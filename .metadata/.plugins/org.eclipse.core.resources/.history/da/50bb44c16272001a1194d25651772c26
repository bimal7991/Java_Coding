package codechef;
import java.util.*;
public class PRFXGD {
  public static void main(String[] args) {
   Scanner sc=new Scanner(System.in);
   int T=sc.nextInt();
   while(T-->0)
   {
	   String str=sc.next();
	   sc.nextLine();
	   int k=sc.nextInt(),x=sc.nextInt();
	   int arr[]=new int[26];
	   if(k==0)
	   { 
	   int i=0;
	   for( i=0;i<str.length();i++)
	   {
		   arr[i]=str.charAt(i)-'a';
		   if(arr[i]>x)
		   {
			   break;
		   }
	   }
	    System.out.println();
	   }
   }
}
}
