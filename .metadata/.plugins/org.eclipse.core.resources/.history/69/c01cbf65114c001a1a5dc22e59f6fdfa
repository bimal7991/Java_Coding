package codechef;
import java.util.*;
public class NOCHANGE {
 public static void main(String[] args) {
	 Scanner sc=new Scanner(System.in);
	 int T=sc.nextInt();
	 while(T-->0)
	 {
		 int N=sc.nextInt(),P=sc.nextInt();
		 int arr[]=new int[N];
		 for(int i=0;i<N;i++)
			 arr[i]=sc.nextInt();
		 
		 int count[]=new int[N];
		 if(change(arr,P))
		 {
			 System.out.println("NO");
		 }
		 else
		 {
			 long sum=0;
			 int rem=P;
			 int i=N-1;
			 while(sum<P && i>=0)
			 {
				 int k=rem/arr[i];	
				 if(k==0)
					 break;
				 
				 if((sum+k*arr[i])<P)
				 {
					 rem=rem-k*arr[i];
					 sum=sum+k*arr[i];
					 count[i]=k;
				     
				 }
				 i--;

			 }
			 for(int j=0;j<i;j++)
			 {
				 int k=rem/arr[j];
				 rem=rem-k*arr[i];
				 sum=sum+k*arr[i];
				 count[j]=k;
				 if(sum>P)
				 {
					 count[j-1]++;
					 break;
				 }
			 }
			 for(int j=0;j<N;j++)
			 {
				 System.out.print(count[j]+" ");
			 }
			 
			 
		 }
		 
		 
		 
	 }
}

private static boolean change(int[] arr,int P) {
	// TODO Auto-generated method stub
	for(int i=0;i<arr.length;i++)
	{
		if(P%arr[i]!=0)
			return false;
	}
	
	
	return true;
}
    
 
 
}
