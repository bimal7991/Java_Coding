package codechef;
import java.util.*;
public class Flip_card {
public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int t=sc.nextInt();
	for(int j=0;j<t;j++)
	{
		String s=sc.next();
		char arr[]=s.toCharArray();
		int count1=0,count0=0;
		for(int i=0;i<s.length();i++)
		{
			if(arr[i]=='1')
			{
				if(i>0 && i!=s.length()-1 && arr[i-1]!='2' && arr[i+1]!='2')
				{
					if(arr[i-1]=='1' )
						arr[i-1]='0';
					else
						arr[i-1]='1';
					
					if(arr[i+1]=='1' )
						arr[i+1]='0';
					else
						arr[i+1]='1';
					
				}
				else if(i==0 && arr[i+1]!='2')
				{
					if(arr[i+1]=='1' && arr[i+1]!=-1)
						arr[i+1]='0'; 
					else
						arr[i+1]='1';
				}
					
				else if(i==s.length()-1 && arr[i-1]!='2')
				{
					if(arr[i-1]=='1')
						arr[i-1]='0';
					else
						arr[i-1]='1';
				}
					
		
				arr[i]='2';
				i=0;
						
				
			}
				
			else
			{}
			
				
		}
		for(int i=0;i<s.length();i++)
		{
			System.out.print(arr[i]+" ");
			
		}
		if(count0!=1)
			System.out.println("WIN");
		else
		System.out.println("LOSE");
		
	}
}
}
