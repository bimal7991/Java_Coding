package codechef;

import java.util.Scanner;

public class NITGOC {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		while(T-->0)
		{
			long a=sc.nextLong(),b=sc.nextLong();
			if(gcd(a-1,b-1)==1)
				System.out.println("YES");
			else
				System.out.println("NO");
			
			
		}
	}
	static long gcd(long l, long m) 
    { 
      if (m == 0) 
        return l; 
      return gcd(m, l % m);  
    } 
}
