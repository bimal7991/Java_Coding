package codechef;
import java.util.*;
public class CHEFSETC {
public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int t=sc.nextInt();
	while(t-->0)
	{
		int arr[]=new int[4];
		for(int i=0;i<4;i++)
			arr[i]=sc.nextInt();
		int sub[]=new int[16];
		int flag=0;
		for(int i=1;i<16;i++)
		{
			int sum=0;
		    for(int j=0;j<4;j++)
		    {
		    	int set=1<<j;
		    	if((i&set)!=0)
		    	{
		    	   sum=sum+arr[j];	
		    	}
		    }
		    
		    sub[i]=sum;
		}
		for(int i=1;i<=15;i++)
		{
			if(sub[i]==0)
			{
				flag=1;
				break;
			}
		}
		if(flag==0)
		System.out.println("NO");
		else
			System.out.println("YES");
	}
}
}
