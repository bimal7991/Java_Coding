package codechef;
import java.util.*;
public class CHEFRAIL {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	 while(T-->0)
	 {
		 int N=sc.nextInt();
		 int M=sc.nextInt();
		 int X[]=new int[N];
		 int Y[]=new int[M];
		 
		 
		 for(int i=0;i<N;i++)
		 {
			 X[i]=sc.nextInt();
			
		 }
		 for(int i=0;i<M;i++)
		 {
			 Y[i]=sc.nextInt();
		 }
		 int count=0;
		 for(int i=0;i<N;i++)
		 {
			 
			 for(int j=0;j<M;j++)
			 {
				 
				 for(int k=j+1;k<M;k++)
				 {
					 
					 if(Right(X[i],0,0,Y[j],0,Y[k]))
					 {
						count++; 
						
						
					 }
					 
				 }
				 
			 }
		 }
		 for(int i=0;i<M;i++)
		 {
			
			 for(int j=0;j<N;j++)
			 {
				 for(int k=j+1;k<N;k++)
				 {
					 if(Right(0,Y[i],X[j],0,X[k],0))
					 {
						 count++;
						
					 }
				}
				
				 
			}
		 }
		 System.out.println(count);
		 
		 }
		 
	 
}

private static boolean Right(int x1, int y1, int x2, int y2, int x3, int y3) {
	
	int dis[]=new int[3];
	// TODO Auto-generated method stub
	dis[0]=distance(x1, y1, x2, y2);
	dis[1]=distance(x1, y1, x3, y3);
	dis[2]=distance(x3, y3, x2, y2) ;
	 //System.out.println(dis[0]+" "+dis[1]+" "+dis[2]);
	 
	
	if(dis[2]==dis[0]+dis[1] || dis[0]==dis[1]+dis[2] || dis[1]==dis[0]+dis[2])
	{
		return true;
	}
	else
	{
		return false;
	}
	
	
}
static int distance(int x1, int y1, int x2, int y2) 
{ 
    // Calculating distance 
    return  (x2 - x1)*(x2-x1) +  (y2 - y1)* (y2-y1); 
} 
}
