package codechef;
import java.util.*;
public class First {
 public static void main(String[] args) {
	int t;
	Scanner sc=new Scanner(System.in);
	t=sc.nextInt();
	for(int i=0;i<t;i++)
	{
		int n=sc.nextInt();
		int k=1,x=0,y=0,count=0;
		while(k<=n)
		{
			if(k*k>y)
			{
				x=k;
				y=y+k*k;
				count++;
			}
		}
		System.out.println(count);
		
		
	}
	
}
}
