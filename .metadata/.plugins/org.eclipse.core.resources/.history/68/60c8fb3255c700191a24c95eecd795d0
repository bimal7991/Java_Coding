       for(int T=0;T<t;T++)
       {
    	   int a=sc.nextInt(),b=sc.nextInt(),n=sc.nextInt(),n1=0;
    	   if(n==0)
    		   System.out.println(a);
    	   else if(n==1)
    		   System.out.println(b);
    	   else
    	   {
    		   int f[] = new int[n + 1]; 
    	        int i; 
    	  
    	        /* 0th and 1st number of the series are 0 and 1*/
