package codechef;
import java.util.*;
public class Merge_Sort {
	 public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		while(T-->0)
		{
			int n=sc.nextInt();
			int arr[]=new int[n];
			for(int i=0;i<n;i++)
				arr[i]=sc.nextInt();
			
			int ans=merge_sort(arr,0,n-1);
			
			for(int i=0;i<n;i++)
			{
				System.out.print(arr[i]+" ");
			}
			
			
		}
	}

	private static int merge_sort(int[] arr, int l, int r) {
		// TODO Auto-generated method stub
		int count=0;
		  if(l<r)
		  {
			  int mid=(l+r)/2;
			  count+=merge_sort(arr, l, mid);
			 count += merge_sort(arr, mid+1, r);
			  count+=merge(arr, l,mid+1, r);
			  
		  }	
		  return count;
	}

	private static int  merge(int[] arr, int l, int mid, int r) {
		// TODO Auto-generated method stub
		   int temp[]=new int[r+1];
		   int count=0;
		   int ind=l;
		   int i=l,j=mid;
		   while(i<=mid-1 && j<=r)
		   {
			   if(arr[i]<=arr[j])
			   {
				   temp[ind++]=arr[i];
				   i++;
			   }
			   else
			   {
				   temp[ind++]=arr[j];
				   j++;
				   count=count+(mid-i);
			   }
			     
		   }
		   
		   while(i<=mid-1)
		   {
			   temp[ind++]=arr[i];
			   i++;
		   }
		   
		   while(j<=r)
		   {
			   temp[ind++]=arr[j];
			   j++;
		   }
		   
		   for(int k=l;k<=r;k++)
			   arr[k]=temp[k];
			   
		   return count;
		
		
		
	}
	

}
