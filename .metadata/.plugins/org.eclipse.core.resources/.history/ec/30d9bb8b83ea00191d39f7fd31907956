package codechef;
import java.util.*;
public class Matrix_odd {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int t=sc.nextInt();
	for(int i=0;i<t;i++)
	{
		int n=sc.nextInt(),m=sc.nextInt(),q=sc.nextInt();
		//int arr[][]=new int[n][m];
		int r[]=new int[n+1];
		int c[]=new int[m+1];
		for(int j=0;j<q;j++)
		{
			 r[sc.nextInt()]++;
			 c[sc.nextInt()]++;         
		
		}
		 
		
		int count=0;
		for(int j=1;j<r.length;j++)
		{
			if(r[j]%2==0)
			for(int k=1;k<c.length;k++)
			{
				
				if(c[k]%2!=0)
				count++;
			}
			else
				for(int k=1;k<c.length;k++)
				{
					
					if(c[k]%2==0)
					count++;
				}
		}
		
		
		System.out.println(count);
		
	}
}
}