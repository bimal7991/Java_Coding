package codechef;
import java.util.*;
public class Nochange {
  public static void main(String[] args) {
	  Scanner sc=new Scanner(System.in);
	int  T=sc.nextInt();
	  for(int t=0;t<T;t++)
	  {
		  int N=sc.nextInt(),P=sc.nextInt();
		  int arr[]=new int[N];
		 
		  int count[]=new int[N];
		  
		  
		  
		  for(int i=0;i<N;i++)
		  {
			  arr[i]=sc.nextInt();
		  }
		  int mult []=new int[2];
		  int k=1;
		  for(int i=N-1;i>=0 && k>=0 ;i--)
		  {
			  if(P%arr[i]!=0)
				  mult[k--]=i;
			 
		  }
		  
		  
		  int m1=arr[0],flag=0;
		  for(int i=1;i<N;i++)
		  {
			 if(arr[i]%m1==0)
				 m1=arr[i];
			 else
			 {
				 flag=1;
				 break;
			 }
		  }
		  if(flag==0)
		  {
			 if(P%arr[N-1]==0)
			 {
				 System.out.println("NO");
			 }
			 else
			 {
				 System.out.print("YES"+" ");
				 count[N-1]=P/arr[N-1]+1;
				 for(int i=0;i<N;i++)
				 {
					 System.out.print(count[i]+" ");
				 }
				 System.out.println();
			 }
			  
		  }
		  else
		  {
			  
			  
			  
		  }
		  
	  }
}
}
