package codechef;
import java.util.*;
public class NODE_DISTANCE {
   public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
		int n=sc.nextInt();
		for(int i=1;i<=n;i++)
			arr[i]=new ArrayList<Integer>();
		
		for(int i=1;i<=n;i++)
			for(int j=0;j<=maxN;j++)
			{
			  LCA[i][j]=-1;	
			}
		
		for(int i=1;i<n;i++)
		{
			int a=sc.nextInt(),b=sc.nextInt();
			arr[a].add(b);
			arr[b].add(a);
		}
		
		
		init(n);
		
		int q=sc.nextInt();
		while(q-->0)
		{
			int a=sc.nextInt(),b=sc.nextInt();
			System.out.println(getDist(a, b));
		}
		
	}
}
 private static void init(int n) {
	// TODO Auto-generated method stub
	 dfs(1,0,-1);
	 
	 for( int i=1;i<=maxN;i++)
	 {
		 for(int j=1;j<=n;j++)
		 {
			if(LCA[j][i-1]!=-1)
			{
				int par=LCA[j][i-1];
				LCA[j][i]=LCA[par][i-1];
			}
		 }
	 }
}
 
 
private static void dfs(int node, int lvl, int par) {
	
	// TODO Auto-generated method stub
	level[node]=lvl;
	LCA[node][0]=par;
	for(int child:arr[node])
	{
		if(child!=par)
		{
			dfs(child,lvl+1,node);
		}
	}
}

static int getLca(int a,int b)
{
	if(level[a]>level[b])
	{
		int temp=a;
		a=b;
		b=temp;
	}
	int d=level[b]-level[a];
	while(d>0)
	{
		int i=(int)Math.log(d);
		b=LCA[b][i];
		d-=1<<i;
		
	}
	if(a==b)
		return a;
	
	for(int i=maxN;i>=0;i--)
	{
		if(LCA[a][i]!=-1 && (LCA[a][i]!=LCA[b][i]))
				{
			      a=LCA[a][i];
			      b=LCA[b][i];
				}
		
	}
	return LCA[a][0];
	
}
static int getDist(int a,int b)
{
	int lca=getLca(a, b);
	return level[a]+level[b]-2*level[lca];
}

	
static ArrayList<Integer> arr[]=new ArrayList[1001];
 static int maxN=10;
 static int level[]=new int[1001];
 static int LCA[][]=new int[1001][maxN+1];
 
   
}
