package codechef;
import java.util.*;

public class ISBIAS {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int N=sc.nextInt(),Q=sc.nextInt();
	int arr[]=new int[N];
	for(int i=0;i<N;i++)
	{
		arr[i]=sc.nextInt();
		
	}
	for(int q=0;q<Q;q++)
	{
		int R=sc.nextInt(),L=sc.nextInt();
		int count1=0,no=0;
	    for(int i=R;i<L-1;i++)
	    {
	    	if(arr[i]<arr[i+1])
	    	{
	    		no++;
	    		continue;
	    	}
	    	else
	    	{
	    		if(no>=1)
	    		{
	    		count1++;
	    		no=0;
	    		}
	    	}
	    		
	    }
	    int count2=0,no1=0;
	    for(int i=R;i<L-1;i++)
	    {
	    	if(arr[i]>arr[i+1])
	    	{
	    		no1++;
	    		continue;
	    	}
	    	else
	    	{
	    		if(no1>=1)
	    		{
	    		 count2++;
	    		 no1=0;
	    		}
	    	}
	    		
	    }
	    System.out.println(count1+" "+count2);
	}
}
}
