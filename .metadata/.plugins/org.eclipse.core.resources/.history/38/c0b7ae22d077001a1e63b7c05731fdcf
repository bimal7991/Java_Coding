package codechef;
import java.util.*;
public class SQRDSUB {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		while(T-->0)
		{
			int N=sc.nextInt();
			int arr[]=new int[N];
			for(int i=0;i<N;i++)
				arr[i]=sc.nextInt();
			
			int count=0;
			
			for(int i=0;i<N;i++)
			{
				if(arr[i]%2==1)
					count++;
			}
			
			for(int i=0;i<N;i++)
			{
				//long mult=1;
				
			
				int ind=0;
				int count2=0;
				
				for(int j=i;j<N;j++)
				{
					if(arr[j]%2==0)
						count2++;
					
					if(count2==2)
					{
						ind=j;
						break;
					}	
					
				}
				count=count+(N-ind+1);
				
				
				
			}
			System.out.println(count);
			
		}
	}

}
