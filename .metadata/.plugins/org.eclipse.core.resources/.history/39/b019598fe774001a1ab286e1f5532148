package codechef;
import java.util.*;
	
public class FUNRUN {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
		int n=sc.nextInt();
	    long max1=0;
	    for(int i=0;i<n;i++)
	    {
	    	long a=sc.nextLong();
	    	if(a>max1)
	    		max1=a;
	    }
	    long max2=0;
	    for(int i=0;i<n;i++)
	    {
	    	long a=sc.nextLong();
	    	if(a>max2)
	    		max2=a;
	    }
	    if(max1==max2)
	    	System.out.println("NO");
	    else
	    	System.out.println("YES");
	    
	}
}
}
