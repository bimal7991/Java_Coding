package codechef;

import java.util.Scanner;

public class Match {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int d,a=0,b=0;
		int arr[]=new int[3];
		for(int i=0;i<3;i++)
		{
		 arr[i]=sc.nextInt();
		}
		d=sc.nextInt();
		for(int i=0;i<3-1;i++)
		{
			for(int j=0;j<3-i-1;j++)
				if(arr[j]>arr[j+1])
				{
					int tmp=arr[j+1];
					arr[j]=arr[j+1];
					arr[j+1]=tmp;
				}
		}
		
		if(Math.abs(arr[1]-arr[0])>=d)
		{
			if(Math.abs(arr[2]-arr[1])<d)
				System.out.println(d-(arr[2]-arr[1]));
		}
		else if(Math.abs(arr[2]-arr[1])>=d)		
		{
			if(Math.abs(arr[1]-arr[0])<d)
				System.out.println(d-(arr[1]-arr[0]));
		}
		else
		{
			if(Math.abs(arr[1]-arr[0])<d)
			{
				a=d-(arr[1]-arr[0]);
			}
			if(Math.abs(arr[2]-arr[1])<d)
			{
			  b=d-(arr[2]-arr[1]);	
			}
			if(a>b)
				System.out.println(a);
			else
				System.out.println(b);
				
		
		}
		
		
	}

}
