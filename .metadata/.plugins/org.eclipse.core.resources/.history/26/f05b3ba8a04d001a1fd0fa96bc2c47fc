package codechef;
import java.util.*;
public class NOCHANGE {
 public static void main(String[] args) {
	 Scanner sc=new Scanner(System.in);
	 int T=sc.nextInt();
	 while(T-->0)
	 {
		 int N=sc.nextInt(),P=sc.nextInt();
		 int arr[]=new int[N];
		 for(int i=0;i<N;i++)
			 arr[i]=sc.nextInt();
		 
		 int count[]=new int[N];
		 if(change(arr,P))
		 {
			 System.out.println("NO");
		 }
		 else
		 {
			 long sum=0;
			 long rem=P;
			 //int i=N-1;
			 int i;
			 for( i=N-1;i>=0;i--)
			 {
			        if(rem%arr[i]==0)
			        {
			        	count[i]=(int) (rem/arr[i]-1);
			        	rem=rem-count[i]*arr[i];
			        	break;
			        }
			        else
			        {
			        	count[i]=(int) (rem/arr[i]);
			        	rem=rem-count[i]*arr[i];
			        }
			        
			 }
			 if(rem>0)
			 {
				 if(rem/arr[0]==0)
				 {
					 count[i]++;
				 }
				 else
				 {
					 int k=(int) (rem/arr[0])+1;
					 int extrrem=(int) (rem+arr[i]*count[i]);
					 int st=extrrem/arr[0]+1;;
					 if((k*arr[0]+arr[i]*count[i])<st*arr[0])
                   {
                	 count[i]=k  ;
                	 
                   }
					 else
					 {
						 count[0]=st;
					    count[i]=0;
					 }
				 }
					 
			 }
			 
			 
			 
			 
			 System.out.print("YES ");
			 for(int j=0;j<N;j++)
			 {
				 
				 System.out.print(count[j]+" ");
			 }
			 
			 
		 }
		 
		 
		 
	 }
}

private static boolean change(int[] arr,int P) {
	// TODO Auto-generated method stub
	for(int i=0;i<arr.length;i++)
	{
		if(P%arr[i]!=0)
			return false;
	}
	
	
	return true;
}
    
 
 
}
