package codechef;
import java.util.*;
public class Max_product_sum {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int t=sc.nextInt();
		for(int i=0;i<t;i++)
		{
		int n=sc.nextInt();
		int arr[]=new int[n];
		for(int j=0;j<n;j++)
		{
			arr[j]=sc.nextInt();
		}
		int large=sum(arr[0]),pos=0;
		
		for(int j=1;j<n;j++)
		{
		 if(sum(arr[j])>large)
		 {
			 large=arr[j];
			 pos=j;
		 }
		}
		int large2=sum(arr[0]);
		for(int j=1;j<n;j++)
		{
		 if(sum(arr[j])>large2 && j!=pos)
		 {
			 large2=arr[j];
			
		 }
		}
		long ans=sum(large*large2);
		
		
		
		
	}
	}

	private static int sum(int i) {
		// TODO Auto-generated method stub
		int s=0;
		while(i!=0)
		{
			int k= int(i%10);
			s=s+k;
			i=i/10;
			
		}
		
		return s;
	}
}
