package codechef;
import java.util.*;
public class LAZER1 {
  public static void main(String[] args) {
	  Scanner sc=new Scanner(System.in);
	    int T=sc.nextInt();
	    while(T-->0)
	    {
	    	int N=sc.nextInt(),Q=sc.nextInt();
	    	int A[]=new int[N];
	    	for(int i=0;i<N;i++)
	    	{
	    		A[i]=sc.nextInt();
	    	}
	    	
	    	
	    	for(int i=0;i<Q;i++)
	    	{
	    		int x1=sc.nextInt(),x2=sc.nextInt(),y=sc.nextInt();
	    		int count=0;
	    	   //new
	    		int start=0,end=0;
	    		for(int j=x1-1;j<x2-1;j++)
	    		{
	    			if((A[j]<=y && A[j+1]>=y )|| (A[j]>=y && A[j+1]<=y))
	    			{
	    				start=j;
	    				break;
	    			}
	    		}
	    		for(int j=x2-1;j>x1-1;j--)
	    		{

	    			if((A[j]<=y && A[j-1]>=y )|| (A[j]>=y && A[j-1]<=y))
	    			{
	    				end=j;
	    				break;
	    			}
	    		}
	    		
	    		    
	    		
	    		
	    		
	    		for(int j=start;j<end;j++)
	    		{
	    			if((A[j]<=y && A[j+1]>=y )|| (A[j]>=y && A[j+1]<=y))
	    			{
	    				count++;
	    			}
   		}
	    		System.out.println(count);
	    	}
	    	
	    	
	    }
  }
}
