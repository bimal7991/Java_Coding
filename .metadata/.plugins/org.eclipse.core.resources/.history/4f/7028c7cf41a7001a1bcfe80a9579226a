package codechef;
import java.util.*;
public class EOEO1 {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
		int n=sc.nextInt();
		if(n%2==0)
		{
			int a=n;
			int count=0;
			for(int i=n-2;i>=1;i-=2)
			{
				while(true)
				{
					
					if(a%2==0 && i%2==1)
						break;
					else if(a%2==1 && i%2==0)
					{
						count++;
						break;
					}
					else if(a%2==1 && i%2==1)
					{
						break;
					}
					
					a=a/2;
					i=i/2;
				}
				
			}
			System.out.println(count);
			
		}
		else
			System.out.println(n/2);
	}
}
}
