package codechef;
import java.util.*;
	
public class FUNRUN {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
		long A=sc.nextLong();
		long B=sc.nextLong();
		int len=Long.toBinaryString(B).length();
	    long max=0;
	    int op=0;
	    for(int i=1;i<len;i++)
	    {
	       long b=rightRotate(B, i,len);
	       System.out.println(b);
	       long val=A^b;
	       if(val>max)
	       {
	    	   max=val;
	    	   op=i;
	       }
	       
	    }
		
		System.out.println(op+" "+max);
	    
	}
	
	
	
}
  
  static long rightRotate(long n, int d,int len) { 
      
	    /* In n>>d, first d bits are 0.  
	       To put last 3 bits of at 
	       first, do bitwise or of n>>d  
	       with n <<(INT_BITS - d) */
	    return (n >> d) | (n << (len - d)); 
	} 
}
