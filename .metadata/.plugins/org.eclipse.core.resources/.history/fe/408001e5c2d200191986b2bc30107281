package codechef;
import java.util.*;
public class Fib_seq {
	public static void main(String[] args) {
		
		Scanner sc=new Scanner(System.in);
		int t=sc.nextInt();
		for(int T=0;T<t;T++)
		{
			long n=sc.nextInt();
			n=n%60;
		   int fib[]=new int[(int) n];
		   fib[0]=0;
		   fib[1]=1;
		   for(int i=2;i<=n;i++)
		   {
			   fib[i]=fib[i-1]+fib[i-2];
		   }
		    int k=1;
			while(Math.pow(2, k)<=n)
			{
				k++;
			}
			long limit= (long) (Math.pow(2, k-1)-1);
			//System.out.println(fib[(int) (Math.pow(2, i-1)-1)]);
			//System.out.println(fib(limit-1));
			System.out.println(fib[(int) limit]%10);
			
		}
		
}
	static long fib(long limit) { 
		double phi = (1 + Math.sqrt(5)) / 2; 
		return (long) Math.round(Math.pow(phi, limit)  
		                        / Math.sqrt(5)); 
		} 
}
