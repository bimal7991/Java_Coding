package codechef;
import java.util.*;
public class PSHOT {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int T=sc.nextInt();
	while(T-->0)
	{
		int n=sc.nextInt();
		String s=sc.next();
		int ahit=0,amis=0,bhit=0,bmis=0;
		int ind=2*n;
		for(int i=0;i<2*n;i++)
		{
			
			
			if(i%2==0 && s.charAt(i)=='1')
				ahit++;
			else if(i%2==1 && s.charAt(i)=='1')
				bhit++;
			else {}
				    
			
			if(ahit-bhit>=(n-i/2))
			{
				ind=i+1+1;
				break;
			}
			
				
		}
		System.out.println(ind);
		
	}
}
}
