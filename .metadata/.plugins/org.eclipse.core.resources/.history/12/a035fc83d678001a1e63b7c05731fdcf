package codechef;
import java.util.*;
public class SQRDSUB {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int T=sc.nextInt();
		while(T-->0)
		{
			int N=sc.nextInt();
			int arr[]=new int[N];
			for(int i=0;i<N;i++)
				arr[i]=sc.nextInt();
			
			long count=0;
			for(int i=0;i<N;i++)
			{
				if(arr[i]<0)
					arr[i]=-arr[i];
					
			}
			
			
//			for(int i=0;i<N;i++)
//			{
//				if(arr[i]%2==1)
//					count++;
//			}
			//System.out.println(count);
			for(int i=0;i<N;i++)
			{
				//long mult=1;
				int index0=N;
				for(int j=i;j<N;j++)
				{
					if(arr[j]==0)
					{
						index0=j;
						break;
					}
				}
				int index2=index0,flag=0,flag4=0;
				for(int j=i;j<index0;j++)
				{
					if(arr[j]%4==0)
					{
					    flag4=1;
					    flag=1;
					    index2=j;
						break;
					}
					else if(arr[j]%2==0)
					{
						flag=1;
					    index2=j;
						break;
					}
					
				}
				
				count=count+(index2-i);
				
				
				if(flag==1)
				{	
				int index4=index0,flag2=0;
				if(flag4==1)
				{
					count=count+(index4-index2);
				}
					
				for(int j=index2+1;j<index0;j++)
				{
					if(arr[j]%2==0)
					{
						index4=j;
						flag2=1;
						break;
					}
				}
				if(flag2==1)
					count=count+(index0-index4);
				
				}
				
				
				
				//System.out.println(count);
				
			}
			System.out.println(count);
			
		}
	}

}
