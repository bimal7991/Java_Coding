package codechef;
import java.util.*;
public class Quick_Sort {
  public static void main(String[] args) {
	Scanner sc=new Scanner(System.in);
	int n=sc.nextInt();
	int arr[]=new int[n];
	for(int i=0;i<n;i++)
		arr[i]=sc.nextInt();
	
	quicksort(arr,0,n-1);
	
	for(int i=0;i<n;i++)
		System.out.print(arr[i]+" ");
	
	
}

private static void quicksort(int[] arr, int start, int end) {
	// TODO Auto-generated method stub
	if(start<end)
	{
		int pindex=partion(arr,start,end);
		quicksort(arr, start, pindex-1);
		quicksort(arr, pindex+1, end);
	}
	
	
}

private static int partion(int[] arr, int start, int end) {
	// TODO Auto-generated method stub
	int pindex=start;
	int pivot=arr[end];
	for(int i=start;i<end;i++)
	{
		if(arr[i]<pivot)
		{
			int temp=arr[i];
			arr[i]=arr[pindex];
			arr[pindex]=temp;
			pindex++;
		}
	}
	int temp=arr[end];
	arr[end]=arr[pindex];
	arr[pindex]=temp;
	return pindex;
}
}
