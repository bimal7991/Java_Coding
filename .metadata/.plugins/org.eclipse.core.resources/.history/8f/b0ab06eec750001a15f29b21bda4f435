package codechef;


import java.util.*;
 class LongCook1 {
  public static void main(String[] args) {
	 Scanner sc=new Scanner(System.in);
	 
	 int T=sc.nextInt();
	 while(T-->0)
	 {
		 int month1=sc.nextInt(),year1=sc.nextInt(),month2=sc.nextInt(),year2=sc.nextInt();
		 int count=0;
		 if(month1>2)
			 year1++;
		 if(month2<=1)
			 year2--;
		 for(int i=year1;i<=year2;i++)
		 {
			 if(checkYear(i))
			 {
				 if(method(i)==0)
					 count++;
			 }
			 else
			 {
				 if(method(i)==0 || method(i)==1)
					 count++;
			 }
		 }
		 
		 
		 
		 
		 System.out.println(count);
		 
	 }
}
  static int method(int year) 
{ 
          year--;
        
         int k = year % 100; 
         int j = year / 100; 
         int h =  40 + k + k / 4 + j / 4 + 5 * j; 
         h = h % 7; 
        return h;
}
  
  static boolean checkYear(int year) 
  { 
     
      if (year % 400 == 0) 
          return true; 
    
      
      if (year % 100 == 0) 
          return false; 
    
   
      if (year % 4 == 0) 
          return true; 
      return false; 
  } 
  
}

