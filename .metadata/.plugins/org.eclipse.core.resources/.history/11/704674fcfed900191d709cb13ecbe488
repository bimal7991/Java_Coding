package codechef;
import java.util.*;
public class Alice {
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);

		int n=sc.nextInt();
		int arr[]=new int[n];
		for(int i=0;i<n;i++)
		{
			arr[i]=sc.nextInt();
		}
		int m=sc.nextInt();
		int arr1[]=new int[m];
		for(int i=0;i<m;i++)
		{
			arr1[i]=sc.nextInt();
		}
		int arr2[]=new int[m+n];
		for(int i=0;i<n;i++)
			arr2[i]=arr[i];
		for(int i=n;i<m+n;i++)
			arr2[i]=arr1[i-n];
		Arrays.sort(arr2);
		 for(int j=0;j<m+n;j++)
		 {
			System.out.print(arr2[j]+" ");
		 }
		
		
        for(int i=0;i<m;i++)
        {
        	int count=0;
           for(int j=m+n-1;j>0;j--)
           {
        	  if(arr2[j]!=arr2[j+1])
        		  count++;
        	  if(j==m+n-1)
        	  {
        		  System.out.println(count+1);
        		  
        	  }
        	  else if(arr1[i]==arr2[j])
        	  {
        		  System.out.println(count+1);
        		  break;
        	  }
        	
           }
        }

	}
}
